# Copy this to .env and fill in your values — never commit .env

POSTGRES_DB=netbox
POSTGRES_USER=netbox
POSTGRES_PASSWORD=changeme_strong_password

NETBOX_SECRET_KEY=changeme_50_char_random_string
NETBOX_ADMIN_PASSWORD=changeme_admin_password
NETBOX_ADMIN_EMAIL=admin@infraguardian360.local

REDIS_PASSWORD=changeme_redis_password

KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme_keycloak_password

DOMAIN=your-server-ip-or-domain
ACME_EMAIL=your@email.com

PRODUCT_NAME=InfraGuardian360

# ── Netdisco ──────────────────────────────────────────────────
NETDISCO_DB_PASSWORD=changeme_netdisco_db_password

# ── NetBox Discovery (Diode) ──────────────────────────────────
# Generate from NetBox Admin → API Tokens after first login
NETBOX_DIODE_API_KEY=changeme_generate_from_netbox_admin

# ── Your network seed device ──────────────────────────────────
# Update config/netdisco/netdisco.conf with your first switch IP
SEED_SWITCH_IP=192.168.1.1

# ── SigNoz / ClickHouse ───────────────────────────────────────
CLICKHOUSE_PASSWORD=changeme_clickhouse_password

# ── OpenSearch ────────────────────────────────────────────────
# Must be complex — min 8 chars, upper, lower, number, special
OPENSEARCH_ADMIN_PASSWORD=changeme_opensearch_Admin1!